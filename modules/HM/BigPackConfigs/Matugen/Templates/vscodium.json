{
  "workbench.colorCustomizations": {
    "activityBar.background": "{{ colors.surface_container.default }}",
    "activityBar.foreground": "{{ colors.on_surface.default }}",
    "sideBar.background": "{{ colors.surface_container_low.default }}",
    "sideBar.foreground": "{{ colors.on_surface.default }}",
    "editor.background": "{{ colors.background.default }}",
    "editor.foreground": "{{ colors.on_surface.default }}",
    "editor.selectionBackground": "{{ colors.primary_container.default }}",
    "editor.lineHighlightBackground": "{{ colors.surface_container_high.default }}",
    "statusBar.background": "{{ colors.primary_container.default }}",
    "statusBar.foreground": "{{ colors.on_primary_container.default }}",
    "tab.activeBackground": "{{ colors.surface_container_high.default }}",
    "tab.activeForeground": "{{ colors.primary.default }}",
    "tab.inactiveBackground": "{{ colors.surface_container.default }}",
    "button.background": "{{ colors.primary.default }}",
    "button.foreground": "{{ colors.on_primary.default }}",
    "input.background": "{{ colors.surface_container_highest.default }}",
    "input.foreground": "{{ colors.on_surface.default }}",
    "titleBar.activeBackground": "{{ colors.surface_container.default }}",
    "titleBar.activeForeground": "{{ colors.on_surface.default }}",
    "editorCursor.foreground": "{{ colors.primary.default }}",
    "focusBorder": "{{ colors.primary.default }}",
    "widget.background": "{{ colors.surface_container_low.default }}"
  }
}